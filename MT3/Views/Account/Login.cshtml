@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="min-vh-100 d-flex align-items-center" style="background:linear-gradient(135deg,#c0392b,#e84118,#f39c12);">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-5">
                <div class="card border-0 shadow-lg rounded-4">
                    <div class="card-body p-5">
                        <div class="text-center mb-4">
                            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">
                                <h2 class="fw-bold text-danger"><i class="bi bi-fire me-2 text-warning"></i>Chef<span class="text-dark">VN</span></h2>
                            </a>
                            <p class="text-muted">Chào mừng trở lại, đầu bếp! 👨‍🍳</p>
                        </div>

                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger rounded-3">
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <div><i class="bi bi-exclamation-circle me-1"></i>@error.ErrorMessage</div>
                                }
                            </div>
                        }

                        <form asp-action="Login" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Email</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                                    <input type="email" name="email" class="form-control border-start-0" placeholder="your@email.com" required />
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-semibold">Mật khẩu</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-muted"></i></span>
                                    <input type="password" name="password" class="form-control border-start-0" placeholder="••••••••" required />
                                </div>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="rememberMe" id="rememberMe" />
                                    <label class="form-check-label text-muted small" for="rememberMe">Ghi nhớ đăng nhập</label>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-danger w-100 btn-lg rounded-pill fw-semibold">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                            </button>
                        </form>

                        <hr class="my-4" />
                        <div class="bg-light rounded-3 p-3 mb-3">
                            <p class="small mb-1 fw-semibold">Tài khoản Demo:</p>
                            <p class="small mb-1 text-muted"><i class="bi bi-shield me-1"></i>admin@chefvn.com / Admin@123</p>
                            <p class="small mb-0 text-muted"><i class="bi bi-person me-1"></i>chef@chefvn.com / Chef@123</p>
                        </div>
                        <p class="text-center text-muted mb-0">
                            Chưa có tài khoản? <a asp-action="Register" class="text-danger fw-semibold">Đăng ký miễn phí</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
