@model List<MT3.Models.Recipe>
@{
    ViewData["Title"] = "Quản lý công thức";
}

<div class="container-fluid py-4 px-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill btn-sm"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
        <h2 class="fw-bold mb-0"><i class="bi bi-journal-richtext text-danger me-2"></i>Công thức (@Model.Count)</h2>
    </div>
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Công thức</th>
                            <th>Danh mục</th>
                            <th>Tác giả</th>
                            <th>Trạng thái</th>
                            <th>Ngày tạo</th>
                            <th>Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var recipe in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <img src="@(recipe.ImageUrl ?? "https://images.unsplash.com/photo-1495521821757-a1efb6729352?w=60")"
                                             class="rounded" width="40" height="40" style="object-fit:cover;" />
                                        <span class="fw-semibold">@recipe.Title</span>
                                    </div>
                                </td>
                                <td><span class="badge-category">@recipe.Category?.Name</span></td>
                                <td class="text-muted small">@(recipe.User?.FullName ?? "N/A")</td>
                                <td>
                                    <span class="badge @(recipe.IsPublished ? "bg-success" : "bg-secondary")">
                                        @(recipe.IsPublished ? "Đã đăng" : "Đã ẩn")
                                    </span>
                                </td>
                                <td class="text-muted small">@recipe.CreatedAt.ToString("dd/MM")</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-controller="Recipe" asp-action="Details" asp-route-id="@recipe.Id" class="btn btn-outline-primary btn-sm">Xem</a>
                                        <form asp-action="TogglePublish" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@recipe.Id" />
                                            <button class="btn btn-outline-warning btn-sm">@(recipe.IsPublished ? "Ẩn" : "Hiện")</button>
                                        </form>
                                        <form asp-action="DeleteRecipe" method="post" class="d-inline" onsubmit="return confirm('Xóa?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@recipe.Id" />
                                            <button class="btn btn-outline-danger btn-sm">Xóa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
