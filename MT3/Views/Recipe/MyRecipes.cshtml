@model List<MT3.Models.Recipe>
@{
    ViewData["Title"] = "Công thức của tôi";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold font-display"><i class="bi bi-journal-richtext text-danger me-2"></i>Công thức của tôi</h2>
        <a asp-action="Create" class="btn btn-danger rounded-pill"><i class="bi bi-plus-circle me-2"></i>Thêm công thức</a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-journal display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">Chưa có công thức nào</h4>
            <a asp-action="Create" class="btn btn-danger rounded-pill mt-2">Tạo công thức đầu tiên</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var recipe in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card recipe-card h-100">
                        <div class="img-wrapper">
                            <img src="@(recipe.ImageUrl ?? "https://images.unsplash.com/photo-1495521821757-a1efb6729352?w=400")"
                                 class="card-img-top" alt="@recipe.Title" />
                        </div>
                        <div class="card-body">
                            <span class="badge-category mb-2 d-inline-block">@recipe.Category?.Name</span>
                            <h5 class="fw-bold">@recipe.Title</h5>
                            <div class="stars small mb-2">
                                @for (int i = 1; i <= 5; i++) { <i class="bi @(i <= Math.Round(recipe.AverageRating) ? "bi-star-fill" : "bi-star")"></i> }
                                <span class="text-muted ms-1">(@recipe.RatingCount)</span>
                            </div>
                            <div class="d-flex gap-2 mt-3">
                                <a asp-action="Details" asp-route-id="@recipe.Id" class="btn btn-outline-secondary btn-sm rounded-pill">Xem</a>
                                <a asp-action="Edit" asp-route-id="@recipe.Id" class="btn btn-outline-primary btn-sm rounded-pill">Sửa</a>
                                <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Xóa?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@recipe.Id" />
                                    <button class="btn btn-outline-danger btn-sm rounded-pill">Xóa</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
