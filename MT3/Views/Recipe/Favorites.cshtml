@model List<MT3.Models.Favorite>
@{
    ViewData["Title"] = "Yêu thích";
}

<div class="container py-5">
    <h2 class="fw-bold font-display mb-4"><i class="bi bi-heart-fill text-danger me-2"></i>Công thức đã lưu</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-heart display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">Chưa có công thức nào được lưu</h4>
            <a asp-action="Index" class="btn btn-danger rounded-pill mt-2">Khám phá công thức</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var fav in Model)
            {
                var recipe = fav.Recipe!;
                <div class="col-md-6 col-lg-4">
                    <div class="card recipe-card h-100">
                        <div class="img-wrapper">
                            <img src="@(recipe.ImageUrl ?? "https://images.unsplash.com/photo-1495521821757-a1efb6729352?w=400")"
                                 class="card-img-top" alt="@recipe.Title" />
                        </div>
                        <div class="card-body">
                            <span class="badge-category mb-2 d-inline-block">@recipe.Category?.Name</span>
                            <h5 class="fw-bold">@recipe.Title</h5>
                            <div class="stars small mb-2">
                                @for (int i = 1; i <= 5; i++) { <i class="bi @(i <= Math.Round(recipe.AverageRating) ? "bi-star-fill" : "bi-star")"></i> }
                            </div>
                            <div class="d-flex gap-2 mt-3">
                                <a asp-action="Details" asp-route-id="@recipe.Id" class="btn btn-danger btn-sm rounded-pill flex-grow-1">Xem công thức</a>
                                <form asp-action="ToggleFavorite" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="recipeId" value="@recipe.Id" />
                                    <button class="btn btn-outline-danger btn-sm rounded-pill"><i class="bi bi-heart-fill"></i></button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
