@model MT3.Models.ViewModels.HomeViewModel
@{
    ViewData["Title"] = "Trang chủ - Khám phá công thức tuyệt vời";
}

<!-- Hero Section -->
<section class="hero-section text-white py-5">
    <div class="container position-relative" style="z-index:1">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <p class="text-warning fw-semibold mb-2 fs-5"><i class="bi bi-fire me-2"></i>Chào mừng đến với ChefVN</p>
                <h1 class="display-4 fw-bold font-display mb-3">Hôm nay bạn muốn nấu gì? 🍳</h1>
                <p class="lead mb-4 opacity-90">Khám phá hàng nghìn công thức từ các đầu bếp gia đình và chuyên nghiệp khắp Việt Nam.</p>
                <form asp-controller="Recipe" asp-action="Index" method="get" class="d-flex gap-2 flex-wrap">
                    <input type="search" name="search" class="form-control form-control-lg flex-grow-1 rounded-pill"
                           placeholder="Tìm kiếm theo tên món ăn hoặc nguyên liệu..." style="max-width:420px;" />
                    <button type="submit" class="btn btn-warning btn-lg rounded-pill px-4 fw-bold">
                        <i class="bi bi-search me-2"></i>Tìm kiếm
                    </button>
                </form>
            </div>
            <div class="col-lg-5 d-none d-lg-flex justify-content-end align-items-center">
                <div class="position-relative">
                    <div class="rounded-circle overflow-hidden shadow-lg" style="width:320px;height:320px;">
                        <img src="https://images.unsplash.com/photo-1490645935967-10de6ba17061?w=500" alt="Cooking" style="width:100%;height:100%;object-fit:cover;" />
                    </div>
                    <div class="position-absolute bg-white rounded-3 shadow p-3 text-dark" style="bottom:-20px;left:-30px;">
                        <i class="bi bi-star-fill text-warning me-1"></i><strong>4.8</strong> điểm đánh giá
                    </div>
                    <div class="position-absolute bg-white rounded-3 shadow p-3 text-dark" style="top:20px;right:-30px;">
                        <i class="bi bi-journal-richtext text-danger me-1"></i><strong>@Model.FeaturedRecipes.Count+</strong> recipes
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Category Filter Pills -->
<section class="bg-light py-4 border-bottom">
    <div class="container">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <a href="/Recipe" class="category-pill active">
                <i class="bi bi-grid me-1"></i>Tất cả
            </a>
            @foreach (var cat in Model.Categories)
            {
                <a href="/Recipe?categoryId=@cat.Id" class="category-pill">
                    <i class="bi @(cat.IconClass ?? "bi-tag") me-1"></i>@cat.Name
                </a>
            }
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="py-5">
    <div class="container">
        <div class="row g-4">
            <!-- Recipe Grid -->
            <div class="col-lg-9">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="fw-bold font-display mb-0">✨ Công thức nổi bật</h2>
                    <a href="/Recipe" class="btn btn-outline-danger rounded-pill">Xem tất cả <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
                <div class="row g-4">
                    @foreach (var recipe in Model.FeaturedRecipes)
                    {
                        <div class="col-md-6 col-xl-4 fade-in">
                            <div class="card recipe-card h-100">
                                <div class="img-wrapper">
                                    <img src="@(recipe.ImageUrl ?? "https://images.unsplash.com/photo-1495521821757-a1efb6729352?w=400")"
                                         class="card-img-top" alt="@recipe.Title" loading="lazy" />
                                </div>
                                <div class="card-body d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <span class="badge-category">@recipe.Category?.Name</span>
                                        <span class="text-muted small"><i class="bi bi-clock me-1"></i>@recipe.CookingTime min</span>
                                    </div>
                                    <h5 class="card-title fw-bold mb-1">
                                        <a href="/Recipe/Details/@recipe.Id" class="text-dark text-decoration-none stretched-link">@recipe.Title</a>
                                    </h5>
                                    <p class="card-text text-muted small flex-grow-1">@recipe.Description.Substring(0, Math.Min(90, recipe.Description.Length))...</p>
                                    <div class="d-flex align-items-center justify-content-between mt-2">
                                        <div class="stars">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="bi @(i <= Math.Round(recipe.AverageRating) ? "bi-star-fill" : "bi-star") small"></i>
                                            }
                                            <small class="text-muted ms-1">(@recipe.RatingCount)</small>
                                        </div>
                                        <span class="badge @(recipe.Difficulty == "Easy" ? "badge-easy" : recipe.Difficulty == "Medium" ? "badge-medium" : "badge-hard")">
                                            @recipe.Difficulty
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-3">
                <!-- Trending -->
                <div class="card sidebar-card mb-4">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3"><i class="bi bi-graph-up-arrow text-danger me-2"></i>Xu hướng</h5>
                        @foreach (var (recipe, idx) in Model.TrendingRecipes.Select((r,i) => (r,i+1)))
                        {
                            <a href="/Recipe/Details/@recipe.Id" class="d-flex align-items-center gap-3 mb-3 text-decoration-none text-dark">
                                <span class="fw-bold text-danger fs-5">@idx</span>
                                <img src="@(recipe.ImageUrl ?? "https://images.unsplash.com/photo-1495521821757-a1efb6729352?w=80")"
                                     class="rounded-3" width="60" height="50" style="object-fit:cover;" alt="@recipe.Title" />
                                <div>
                                    <div class="fw-semibold small lh-sm">@recipe.Title</div>
                                    <small class="text-muted">@recipe.CookingTime min</small>
                                </div>
                            </a>
                        }
                    </div>
                </div>

                <!-- Categories -->
                <div class="card sidebar-card mb-4">
                    <div class="card-body">
                        <h5 class="fw-bold mb-3"><i class="bi bi-tags text-danger me-2"></i>Danh mục</h5>
                        <div class="d-flex flex-column gap-2">
                            @foreach (var cat in Model.Categories)
                            {
                                <a href="/Recipe?categoryId=@cat.Id" class="d-flex justify-content-between align-items-center p-2 rounded-3 text-decoration-none text-dark bg-light hover-lift">
                                    <span><i class="bi @(cat.IconClass ?? "bi-tag") me-2 text-danger"></i>@cat.Name</span>
                                    <span class="badge bg-danger-subtle text-danger rounded-pill">@cat.Recipes.Count</span>
                                </a>
                            }
                        </div>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="card sidebar-card" style="background:linear-gradient(135deg,#e84118,#f39c12);">
                    <div class="card-body text-white">
                        <h5 class="fw-bold mb-2"><i class="bi bi-plus-circle me-2"></i>Chia sẻ công thức</h5>
                        <p class="small mb-3 opacity-90">Tham gia cộng đồng và chia sẻ món ăn yêu thích của bạn!</p>
                        <a href="/Recipe/Create" class="btn btn-light btn-sm fw-semibold w-100">Bắt đầu ngay</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="py-5 bg-light">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-md-3">
                <div class="p-3">
                    <div class="display-5 fw-bold text-danger">10+</div>
                    <div class="text-muted">Công thức</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-3">
                    <div class="display-5 fw-bold text-warning">5</div>
                    <div class="text-muted">Danh mục</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-3">
                    <div class="display-5 fw-bold text-success">20+</div>
                    <div class="text-muted">Nguyên liệu</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="p-3">
                    <div class="display-5 fw-bold text-info">100%</div>
                    <div class="text-muted">Miễn phí</div>
                </div>
            </div>
        </div>
    </div>
</section>
