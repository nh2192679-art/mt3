@model MT3.Models.ViewModels.MealPlanViewModel
@{
    ViewData["Title"] = "Lịch ăn";
    var days = new[] { "Thứ 2", "Thứ 3", "Thứ 4", "Thứ 5", "Thứ 6", "Thứ 7", "Chủ nhật" };
    var mealTypes = new[] { "Breakfast", "Lunch", "Dinner" };
}

<div class="container py-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <h2 class="fw-bold font-display mb-0"><i class="bi bi-calendar3 text-danger me-2"></i>Lịch ăn hàng tuần</h2>
        <div class="d-flex gap-2">
            <a asp-action="Index" asp-route-weekStart="@Model.WeekStart.AddDays(-7).ToString("yyyy-MM-dd")" class="btn btn-outline-secondary rounded-pill">
                <i class="bi bi-chevron-left"></i> Tuần trước
            </a>
            <span class="btn btn-light border rounded-pill">@Model.WeekStart.ToString("dd/MM") - @Model.WeekStart.AddDays(6).ToString("dd/MM/yyyy")</span>
            <a asp-action="Index" asp-route-weekStart="@Model.WeekStart.AddDays(7).ToString("yyyy-MM-dd")" class="btn btn-outline-secondary rounded-pill">
                Tuần sau <i class="bi bi-chevron-right"></i>
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-bordered mb-0">
                <thead class="bg-danger text-white">
                    <tr>
                        <th class="p-3" style="width:100px;">Bữa ăn</th>
                        @for (int i = 0; i < 7; i++)
                        {
                            var date = Model.WeekStart.AddDays(i);
                            <th class="p-3 text-center">
                                <div>@days[i]</div>
                                <small class="opacity-75">@date.ToString("dd/MM")</small>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mealType in mealTypes)
                    {
                        <tr>
                            <td class="fw-semibold p-3 bg-light text-center">
                                <i class="bi @(mealType == "Breakfast" ? "bi-sunrise" : mealType == "Lunch" ? "bi-sun" : "bi-moon-stars") d-block mb-1"></i>
                                @(mealType == "Breakfast" ? "Sáng" : mealType == "Lunch" ? "Trưa" : "Tối")
                            </td>
                            @for (int i = 0; i < 7; i++)
                            {
                                var date = Model.WeekStart.AddDays(i);
                                var dateKey = date.ToString("yyyy-MM-dd");
                                var plansForSlot = Model.PlanByDay.ContainsKey(dateKey)
                                    ? Model.PlanByDay[dateKey].Where(p => p.MealType == mealType).ToList()
                                    : new List<MT3.Models.MealPlan>();

                                <td class="p-2" style="min-width:150px; vertical-align:top;">
                                    <div class="meal-slot">
                                        @foreach (var plan in plansForSlot)
                                        {
                                            <div class="meal-item">
                                                <span class="meal-title">@plan.Recipe?.Title</span>
                                                <form asp-action="RemoveMeal" method="post" style="margin:0;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="mealPlanId" value="@plan.Id" />
                                                    <input type="hidden" name="weekStart" value="@Model.WeekStart.ToString("yyyy-MM-dd")" />
                                                    <button type="submit" class="btn-remove" title="Xóa khỏi thực đơn">
                                                        <i class="bi bi-x"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                        <form asp-action="AddMeal" method="post" style="margin-top:4px;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="date" value="@date.ToString("yyyy-MM-dd")" />
                                            <input type="hidden" name="mealType" value="@mealType" />
                                            <input type="hidden" name="weekStart" value="@Model.WeekStart.ToString("yyyy-MM-dd")" />
                                            <select name="recipeId" class="form-select form-select-sm add-recipe-select" style="font-size:0.78rem;">
                                                <option value="0">+ Thêm...</option>
                                                @foreach (var recipe in Model.AllRecipes)
                                                {
                                                    <option value="@recipe.Id">@recipe.Title</option>
                                                }
                                            </select>
                                        </form>
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-4 p-3 bg-light rounded-4">
        <h6 class="fw-bold text-muted mb-2"><i class="bi bi-lightbulb me-2 text-warning"></i>Mẹo hay</h6>
        <p class="text-muted small mb-0">Lên kế hoạch bữa ăn cả tuần để tiết kiệm thời gian và ăn uống lành mạnh hơn. Chọn công thức từ danh sách để thêm vào từng bữa ăn.</p>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.add-recipe-select').forEach(function (sel) {
            sel.addEventListener('change', function () {
                if (this.value !== '0') {
                    this.closest('form').submit();
                }
            });
        });
    </script>
}
