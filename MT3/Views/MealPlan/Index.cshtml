@model MT3.Models.ViewModels.MealPlanViewModel
@{
    ViewData["Title"] = "Meal Planner";
    var days = new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" };
    var mealTypes = new[] { "Breakfast", "Lunch", "Dinner" };
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <h2 class="fw-bold font-display mb-0"><i class="bi bi-calendar3 text-danger me-2"></i>Weekly Meal Planner</h2>
        <div class="d-flex gap-2">
            <a asp-action="Index" asp-route-weekStart="@Model.WeekStart.AddDays(-7).ToString("yyyy-MM-dd")" class="btn btn-outline-secondary rounded-pill">
                <i class="bi bi-chevron-left"></i> Prev Week
            </a>
            <span class="btn btn-light border rounded-pill">@Model.WeekStart.ToString("MMM dd") - @Model.WeekStart.AddDays(6).ToString("MMM dd, yyyy")</span>
            <a asp-action="Index" asp-route-weekStart="@Model.WeekStart.AddDays(7).ToString("yyyy-MM-dd")" class="btn btn-outline-secondary rounded-pill">
                Next Week <i class="bi bi-chevron-right"></i>
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-bordered mb-0">
                <thead class="bg-danger text-white">
                    <tr>
                        <th class="p-3" style="width:100px;">Meal</th>
                        @for (int i = 0; i < 7; i++)
                        {
                            var date = Model.WeekStart.AddDays(i);
                            <th class="p-3 text-center">
                                <div>@days[i]</div>
                                <small class="opacity-75">@date.ToString("MMM dd")</small>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mealType in mealTypes)
                    {
                        <tr>
                            <td class="fw-semibold p-3 bg-light text-center">
                                <i class="bi @(mealType == "Breakfast" ? "bi-sunrise" : mealType == "Lunch" ? "bi-sun" : "bi-moon-stars") d-block mb-1"></i>
                                @mealType
                            </td>
                            @for (int i = 0; i < 7; i++)
                            {
                                var date = Model.WeekStart.AddDays(i);
                                var dateKey = date.ToString("yyyy-MM-dd");
                                var plansForSlot = Model.PlanByDay.ContainsKey(dateKey)
                                    ? Model.PlanByDay[dateKey].Where(p => p.MealType == mealType).ToList()
                                    : new List<MT3.Models.MealPlan>();

                                <td class="p-2" style="min-width:140px;">
                                    @foreach (var plan in plansForSlot)
                                    {
                                        <div class="meal-slot has-meal mb-2">
                                            <div class="small fw-semibold lh-sm mb-1">@plan.Recipe?.Title</div>
                                            <form asp-action="RemoveMeal" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="mealPlanId" value="@plan.Id" />
                                                <input type="hidden" name="weekStart" value="@Model.WeekStart.ToString("yyyy-MM-dd")" />
                                                <button class="btn btn-link text-danger btn-sm p-0"><i class="bi bi-x-circle"></i></button>
                                            </form>
                                        </div>
                                    }
                                    <form asp-action="AddMeal" method="post" class="d-flex gap-1 flex-column">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="date" value="@date.ToString("yyyy-MM-dd")" />
                                        <input type="hidden" name="mealType" value="@mealType" />
                                        <input type="hidden" name="weekStart" value="@Model.WeekStart.ToString("yyyy-MM-dd")" />
                                        <select name="recipeId" class="form-select form-select-sm">
                                            <option value="0">+ Add...</option>
                                            @foreach (var recipe in Model.AllRecipes)
                                            {
                                                <option value="@recipe.Id">@recipe.Title</option>
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-outline-danger btn-sm w-100">Add</button>
                                    </form>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-4 p-3 bg-light rounded-4">
        <h6 class="fw-bold text-muted mb-2"><i class="bi bi-lightbulb me-2 text-warning"></i>Tips</h6>
        <p class="text-muted small mb-0">Plan your week ahead to save time and eat healthier. Add recipes from the dropdown to each meal slot.</p>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-submit when recipe is selected
        document.querySelectorAll('select[name="recipeId"]').forEach(sel => {
            sel.addEventListener('change', function () {
                if (this.value !== '0') this.closest('form').submit();
            });
        });
    </script>
}
